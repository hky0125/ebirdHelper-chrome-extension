{
  "manifest_version": 3,
  "name": "eBird Helper (Chrome Extension)",
  "version": "2.1.0",
  "description": "Enhances your eBird experience by appending Chinese names, highlighting unseen/endemic species, and enabling @pinyin matching.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://ebird.org/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://ebird.org/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "map/map_bird_eng2chs.json",
        "map/map_endemic.json",
        "map/map_pinyin.json",
        "map/map_uncommon_char_ruby.json"
      ],
      "matches": [
        "https://ebird.org/*"
      ]
    }
  ]
}